                    <Anchor point="CENTER"/>
                </Anchors>
                <Layers>
                    <Layer level="ARTWORK" textureSubLevel="1">
                        <Texture parentKey="IconEmpty" setAllPoints="true" atlas="auctionhouse-itemicon-empty" alpha="0.7">
                            <TexCoords left="0.08" right="0.92" top="0.08" bottom="0.92"/>
                        </Texture>
                    </Layer>
                    <Layer level="ARTWORK" textureSubLevel="2">
                        <Texture parentKey="Icon" setAllPoints="true">
                            <TexCoords left="0.08" right="0.92" top="0.08" bottom="0.92"/>
                        </Texture>
                    </Layer>
                    <Layer level="ARTWORK" textureSubLevel="3">
                        <Texture parentKey="IconBorder" file="Interface/Buttons/UI-Quickslot2">
                            <Size x="52" y="52"/>
                            <Anchors>
                                <Anchor point="CENTER" relativeKey="$parent.Icon"/>
                            </Anchors>
                        </Texture>
                    </Layer>
                    <Layer level="ARTWORK" textureSubLevel="4">
                        <Texture parentKey="FavoriteIcon" atlas="CampCollection-icon-star">
                            <Size x="18" y="17"/>
                            <Anchors>
                                <Anchor point="TOPRIGHT" relativeKey="$parent.Icon" x="4" y="5"/>
                            </Anchors>
                        </Texture>
                    </Layer>
