<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/ ..\..\..\..\..\WoW\Data\Interface\AddOns\Blizzard_SharedXML\UI.xsd">
    <DropdownButton name="KeystoneLootCharacterDropdownTemplate" mixin="KeystoneLootCharacterDropdownMixin" virtual="true">
        <Size x="23" y="24"/>
        <Layers>
            <Layer level="OVERLAY">
                <Texture parentKey="Indicator" atlas="PlayerPartyBlip">
                    <Size x="12" y="12"/>
                    <Anchors>
                        <Anchor point="BOTTOMRIGHT" x="1" y="0"/>
                    </Anchors>
                </Texture>
            </Layer>
        </Layers>
        <NormalTexture parentKey="NormalTexture" atlas="warbands-icon">
            <Size x="23" y="31"/>
            <Anchors>
                <Anchor point="CENTER"/>
            </Anchors>
        </NormalTexture>
        <HighlightTexture parentKey="HighlightTexture" atlas="warbands-icon" alphaMode="ADD" alpha="0.4">
            <Size x="23" y="31"/>
            <Anchors>
                <Anchor point="CENTER"/>
            </Anchors>
        </HighlightTexture>
        <Scripts>
            <OnMouseDown method="OnMouseDown"/>
            <OnMouseUp method="OnMouseUp"/>
        </Scripts>
    </DropdownButton>

    <Frame name="KeystoneLootFrame" parent="UIParent" inherits="ButtonFrameBaseTemplate, TabSystemOwnerTemplate, CallbackRegistrantTemplate" toplevel="true" movable="true" enableMouse="true" clampedToScreen="true" hidden="true" mixin="KeystoneLootFrameMixin">
        <Anchors>
            <Anchor point="CENTER"/>
        </Anchors>
        <Frames>
            <Frame parentKey="TabSystem" inherits="TabSystemTemplate">
                <Anchors>
                    <Anchor point="TOPLEFT" relativePoint="BOTTOMLEFT" x="11" y="2"/>
                </Anchors>
            </Frame>
            <DropdownButton parentKey="SlotDropdown" inherits="WowStyle1DropdownTemplate" mixin="KeystoneLootSlotDropdownMixin">
                <Anchors>
                    <Anchor point="TOP" y="-30"/>
                </Anchors>
            </DropdownButton>
            <DropdownButton parentKey="ClassDropdown" inherits="WowStyle1DropdownTemplate" mixin="KeystoneLootClassDropdownMixin">
                <Anchors>
                    <Anchor point="RIGHT" relativeKey="$parent.SlotDropdown" relativePoint="LEFT" x="-10"/>
                </Anchors>
            </DropdownButton>
            <DropdownButton parentKey="ItemLevelDropdown" inherits="WowStyle1DropdownTemplate" mixin="KeystoneLootItemLevelDropdownMixin">
                <Anchors>
                    <Anchor point="LEFT" relativeKey="$parent.SlotDropdown" relativePoint="RIGHT" x="10"/>
                </Anchors>
            </DropdownButton>
            <DropdownButton parentKey="CharacterDropdown" inherits="KeystoneLootCharacterDropdownTemplate">
                <Anchors>
                    <Anchor point="LEFT" relativeKey="$parent.ItemLevelDropdown" relativePoint="RIGHT" x="17"/>
                </Anchors>
            </DropdownButton>
            <DropdownButton parentKey="SettingsDropdown" frameLevel="510" inherits="UIPanelIconDropdownButtonTemplate" mixin="KeystoneLootSettingsDropdownMixin">
                <Anchors>
                    <Anchor point="TOPRIGHT" x="-28" y="-4"/>
                </Anchors>
            </DropdownButton>
            <Frame parentKey="CatalystFrame" inherits="KeystoneLootCatalystFrameTemplate">
                <Anchors>
                    <Anchor point="TOPLEFT" relativePoint="TOPRIGHT" x="-10" y="-40"/>
                </Anchors>
            </Frame>
        </Frames>
        <Layers>
            <Layer level="ARTWORK">
                <FontString inherits="GameFontDisableSmall" JustifyH="CENTER" JustifyV="MIDDLE" Text="Made with LOVE in Germany">
                    <Size x="400"/>
                    <Anchors>
                        <Anchor point="BOTTOM" y="8"/>
                    </Anchors>
                    <Shadow x="2" y="-2">
                        <Color r="0" g="0" b="0" a="0.4"/>
                    </Shadow>
                </FontString>
            </Layer>
        </Layers>
        <Scripts>
            <OnLoad method="OnLoad"/>
            <OnShow method="OnShow"/>
            <OnHide method="OnHide"/>
            <OnDragStart method="OnDragStart"/>
            <OnDragStop method="OnDragStop"/>
            <OnEvent method="OnEvent"/>
        </Scripts>
    </Frame>
</Ui>