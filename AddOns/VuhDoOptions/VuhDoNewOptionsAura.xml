<Ui xmlns="http://www.blizzard.com/wow/ui" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">

	<Frame name="VuhDoNewOptionsAuraTemplate" virtual="true">
		<Frames>
			<Frame name="$parentRadioPanel">
				<Size>
					<AbsDimension x="115" y="231" />
				</Size>
				<Anchors>
					<Anchor point="TOPRIGHT" relativePoint="TOPRIGHT">
						<Offset>
							<AbsDimension x="0" y="-10" />
						</Offset>
					</Anchor>
				</Anchors>
				<Frames>
					<CheckButton name="$parentGroupsRadioButton" checked="true" text="VUHDO_I18N_GROUPS" inherits="VuhDoTabRadioButtonTemplate">
						<Anchors>
							<Anchor point="TOPLEFT">
								<Offset>
									<AbsDimension x="3" y="-3" />
								</Offset>
							</Anchor>
						</Anchors>
						<Scripts>
							<OnLoad>
								self.tabPanel = "VuhDoNewOptionsAuraGroups";
								VUHDO_lnfCheckButtonOnLoad(self);
								VUHDO_lnfSetTooltip(self, "Configure aura groups");
							</OnLoad>
						</Scripts>
					</CheckButton>
				</Frames>
			</Frame>

			<Frame name="$parentContentPanel">
				<Size>
					<AbsDimension x="428" y="345" />
				</Size>
				<Anchors>
					<Anchor point="TOPLEFT">
						<Offset>
							<AbsDimension x="0" y="0" />
						</Offset>
					</Anchor>
				</Anchors>
				<Frames>
					<Frame name="VuhDoNewOptionsAuraGroups" setAllPoints="true" inherits="VuhDoNewOptionsAuraGroupsTemplate">
					</Frame>
				</Frames>
			</Frame>
		</Frames>
		<Scripts>
			<OnShow>
				VUHDO_auraGroupsOnShow();
			</OnShow>
		</Scripts>
	</Frame>
</Ui>
